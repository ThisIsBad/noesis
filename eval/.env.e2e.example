# Copy to eval/.env.e2e and fill in per-service URLs + bearer secrets.
# Any service whose URL is unset is skipped by the integration suite.
#
# URLs must be the public Railway origin without a trailing slash, e.g.
#   https://mneme-production-abcd.up.railway.app
# Secrets match whatever the service was deployed with (MNEME_SECRET, …).

NOESIS_MNEME_URL=
NOESIS_MNEME_SECRET=

NOESIS_TELOS_URL=
NOESIS_TELOS_SECRET=

NOESIS_PRAXIS_URL=
NOESIS_PRAXIS_SECRET=

NOESIS_LOGOS_URL=
NOESIS_LOGOS_SECRET=

NOESIS_EPISTEME_URL=
NOESIS_EPISTEME_SECRET=

NOESIS_EMPIRIA_URL=
NOESIS_EMPIRIA_SECRET=

NOESIS_TECHNE_URL=
NOESIS_TECHNE_SECRET=

NOESIS_KOSMOS_URL=
NOESIS_KOSMOS_SECRET=
